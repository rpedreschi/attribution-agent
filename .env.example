# Copy this file to ".env" and fill in the values, then run the scripts in GUIDE.md.
# .env is gitignored, so your token stays on your machine.

# --- DeltaStream (Rachel's login) ---
DSQL_BIN=../../dscliv2
DS_SERVER=https://api-mizaz8.deltastream.io/v2
DS_MCP_ENDPOINT=https://api-mizaz8.deltastream.io/mcp/v1
DS_TOKEN=PASTE_DELTASTREAM_API_TOKEN

# --- WarpStream (the demo's Kafka message store) ---
KAFKA_BOOTSTRAP=PASTE_WARPSTREAM_BOOTSTRAP:9092
KAFKA_KEY=PASTE_WARPSTREAM_SASL_USERNAME
KAFKA_SECRET=PASTE_WARPSTREAM_SASL_PASSWORD
KAFKA_CA=config/warpstream-ca.crt

# --- Optional ---
# Enables the agent's written recommendation text. The dashboard renders fine
# without it (recommendations still compute; the wording is just templated).
ANTHROPIC_KEY=
